{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/navigation/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Lama Sans|GE SS Two))/i]",
        "message": "Font not provided by the design system. Available: Lama Sans, GE SS Two."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|bronze|outline|dark|champagne|taupe|green|green-dark|green-light|green-outline|green-sage)$/]",
        "message": "<Badge> variant must be one of 'default' | 'primary' | 'bronze' | 'outline' | 'dark' | 'champagne' | 'taupe' | 'green' | 'green-dark' | 'green-light' | 'green-outline' | 'green-sage'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|onClick|fullWidth|type|href|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, onClick, fullWidth, type, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|dark|bronze|light|green|green-dark|green-outline|green-ghost|green-light)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'dark' | 'bronze' | 'light' | 'green' | 'green-dark' | 'green-outline' | 'green-ghost' | 'green-light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|padding|border|shadow|onClick|radius|style|as|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, padding, border, shadow, onClick, radius, style, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|stone|dark|walnut|champagne|green-dark|green-forest|green-stone|green-mist)$/]",
        "message": "<Card> variant must be one of 'default' | 'stone' | 'dark' | 'walnut' | 'champagne' | 'green-dark' | 'green-forest' | 'green-stone' | 'green-mist'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg|xl)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> radius must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|label|color|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: variant, label, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:line|ornamental|labeled)$/]",
        "message": "<Divider> variant must be one of 'line' | 'ornamental' | 'labeled'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:champagne|walnut|bronze|taupe|green|green-sage|green-pale)$/]",
        "message": "<Divider> color must be one of 'champagne' | 'walnut' | 'bronze' | 'taupe' | 'green' | 'green-sage' | 'green-pale'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|onChange|type|required|disabled|error|hint|name|size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, placeholder, value, onChange, type, required, disabled, error, hint, name, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|tel|password|number|search|url)$/]",
        "message": "<Input> type must be one of 'text' | 'email' | 'tel' | 'password' | 'number' | 'search' | 'url'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Nav'] > JSXAttribute > JSXIdentifier[name!=/^(?:links|ctaLabel|onCtaClick|dark|transparent|logoSrc|logoAlt|key|ref|className|style|children)$/]",
        "message": "<Nav> doesn't accept that prop. Declared props: links, ctaLabel, onCtaClick, dark, transparent, logoSrc, logoAlt."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|options|value|onChange|placeholder|disabled|error|hint|required|name|size|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, options, value, onChange, placeholder, disabled, error, hint, required, name, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Select> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|onChange|required|disabled|error|hint|name|rows|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, placeholder, value, onChange, required, disabled, error, hint, name, rows."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
